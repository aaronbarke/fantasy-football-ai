# Database — docker-compose default shown; use sqlite+aiosqlite:///./dev.db for quick local dev
DATABASE_URL=postgresql+asyncpg://fantasy:fantasy@localhost:5432/fantasy

# Redis cache (optional — app degrades gracefully without it)
REDIS_URL=redis://localhost:6379/0

# Auth
JWT_SECRET=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# AI
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# Google sign-in (optional). Your Google OAuth Web Client ID — no secret needed.
# Leave blank to disable "Continue with Google". See docs/SETUP_GOOGLE_OAUTH.md.
GOOGLE_CLIENT_ID=

# External data
ODDS_API_KEY=

# App
CORS_ORIGINS=http://localhost:3000
ENABLE_SCHEDULER=false
CURRENT_SEASON=2026

# "development" or "production". In production a non-default JWT_SECRET is
# required and admin endpoints are locked down.
ENVIRONMENT=development
# Comma-separated emails allowed to hit admin endpoints (e.g. /api/admin/refresh-stats)
ADMIN_EMAILS=
